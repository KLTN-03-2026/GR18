# Sao chép thành .env và điền giá trị (file .env đã được .gitignore bỏ qua).
# Backend nạp .env trong thư mục làm việc khi chạy RestaurantApplication (MAIL_*, DB_*, JWT_*, …).
# Nếu không dùng .env: export biến trong shell hoặc thêm vào IntelliJ Environment variables — chúng vẫn được ưu tiên.
# Hoặc: SPRING_PROFILES_ACTIVE=local + file application-local.properties (gitignore).

# --- IntelliJ IDEA ---
# Run → Edit Configurations… → chọn Spring Boot run → Environment variables:
#   DB_PASSWORD=mật_khẩu_mysql   (hoặc dùng tên chuẩn Spring: SPRING_DATASOURCE_PASSWORD)
#   JWT_SECRET=...              (chuỗi Base64, ví dụ: chạy  openssl rand -base64 32  trên Git Bash)
# Nhiều biến: dấu ; giữa các cặp KEY=value trên Windows.

# MySQL (hoặc SPRING_DATASOURCE_URL / USERNAME / PASSWORD)
DB_URL=jdbc:mysql://localhost:3306/restaurant_db?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=Asia/Ho_Chi_Minh&allowPublicKeyRetrieval=true&characterEncoding=UTF-8
DB_USERNAME=root
DB_PASSWORD=

# JWT (>= 32 bytes for HS256; ưu tiên Base64, ví dụ: openssl rand -base64 32)
JWT_SECRET=

# Gmail SMTP (App Password)
MAIL_USERNAME=
MAIL_PASSWORD=
# Email nhận khi chạy: gradlew test --tests ReservationConfirmationMailSendIT (mặc định = MAIL_USERNAME)
MAIL_TEST_TO=

# Google Gemini
GEMINI_API_KEY=

# Google OAuth2 đăng nhập
GOOGLE_OAUTH2_CLIENT_ID=
GOOGLE_OAUTH2_CLIENT_SECRET=

# Cloudinary (tùy chọn — đã dùng placeholder trong application.properties)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=image_dish

# --- Docker Compose (docker-compose.yml) ---
# MYSQL_ROOT_PASSWORD=...   (mật khẩu root cho container MySQL)
# JWT_SECRET=...            (Base64 >= 32 byte; có thể dùng cùng khóa dev)
# BACKEND_PORT=8080
# MySQL trong Compose không mở cổng ra host mặc định (tránh trùng 3306). Cần Workbench → thêm ports trong compose hoặc override.
